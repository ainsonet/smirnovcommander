<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SmirnovCommander.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
        x:Class="SmirnovCommander.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="SmirnovCommander">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Панель инструментов -->
        <Grid Grid.Row="0" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <!-- Кнопки для левой панели -->
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button Content="Копировать" Command="{Binding LeftPanel.CopyCommand}" Margin="0,0,5,0" ToolTip.Tip="Ctrl+C"/>
                <Button Content="Вырезать" Command="{Binding LeftPanel.CutCommand}" Margin="0,0,5,0" ToolTip.Tip="Ctrl+X"/>
                <Button Content="Вставить" Command="{Binding LeftPanel.PasteCommand}" Margin="0,0,5,0" ToolTip.Tip="Ctrl+V"/>
                <Button Content="Удалить" Command="{Binding LeftPanel.DeleteCommand}" Margin="0,0,5,0" ToolTip.Tip="Del"/>
                <Separator Width="1" Margin="10,0"/>
                <Button Content="↑" Command="{Binding LeftPanel.GoUpCommand}" Margin="0,0,5,0" ToolTip.Tip="На уровень выше"/>
                <Button Content="↻" Command="{Binding LeftPanel.RefreshCommand}" ToolTip.Tip="Обновить"/>
            </StackPanel>
            
            <!-- Пустая зона в центре -->
            <Grid Grid.Column="1"/>
            
            <!-- Кнопки для правой панели -->
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Content="↻" Command="{Binding RightPanel.RefreshCommand}" Margin="0,0,5,0" ToolTip.Tip="Обновить"/>
                <Button Content="↑" Command="{Binding RightPanel.GoUpCommand}" Margin="0,0,5,0" ToolTip.Tip="На уровень выше"/>
                <Separator Width="1" Margin="10,0"/>
                <Button Content="Удалить" Command="{Binding RightPanel.DeleteCommand}" Margin="0,0,5,0" ToolTip.Tip="Del"/>
                <Button Content="Вставить" Command="{Binding RightPanel.PasteCommand}" Margin="0,0,5,0" ToolTip.Tip="Ctrl+V"/>
                <Button Content="Вырезать" Command="{Binding RightPanel.CutCommand}" Margin="0,0,5,0" ToolTip.Tip="Ctrl+X"/>
                <Button Content="Копировать" Command="{Binding RightPanel.CopyCommand}" Margin="0,0,5,0" ToolTip.Tip="Ctrl+C"/>
            </StackPanel>
        </Grid>

        <!-- Две панели -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*">
            <!-- Левая панель -->
            <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Margin="5" x:Name="LeftPanelBorder">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0" Text="{Binding LeftPanel.CurrentPath}" 
                               Background="#333" Foreground="White" Padding="5"/>
                    <ListBox x:Name="LeftPanelList" Grid.Row="1" ItemsSource="{Binding LeftPanel.Items}"
                             SelectedItem="{Binding LeftPanel.SelectedItem}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="{Binding Name}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding DisplaySize}" 
                                               Foreground="Gray" Margin="10,0,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Правая панель -->
            <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1" Margin="5" x:Name="RightPanelBorder">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0" Text="{Binding RightPanel.CurrentPath}" 
                               Background="#333" Foreground="White" Padding="5"/>
                    <ListBox x:Name="RightPanelList" Grid.Row="1" ItemsSource="{Binding RightPanel.Items}"
                             SelectedItem="{Binding RightPanel.SelectedItem}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="{Binding Name}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding DisplaySize}" 
                                               Foreground="Gray" Margin="10,0,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <!-- Статус бар -->
        <Border Grid.Row="2" Background="#333" Padding="5">
            <Grid ColumnDefinitions="*,Auto,*">
                <TextBlock Grid.Column="0" Text="{Binding LeftPanelStatusBar}" Foreground="White" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="|" Foreground="White" VerticalAlignment="Center" Margin="10,0"/>
                <TextBlock Grid.Column="2" Text="{Binding RightPanelStatusBar}" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
        </Border>
    </Grid>

</Window>