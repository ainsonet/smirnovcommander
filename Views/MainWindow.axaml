<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SmirnovCommander.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="2000" d:DesignHeight="800"
        x:Class="SmirnovCommander.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="SmirnovCommander"
        Width="2000" Height="800" MinWidth="1400" MinHeight="700">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Панель инструментов -->
        <Grid Grid.Row="0" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <!-- Кнопки для левой панели -->
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button x:Name="LeftBackButton" Margin="0,0,5,0" ToolTip.Tip="Назад">
                    <TextBlock Text="⬅️"/>
                </Button>
                <Button x:Name="LeftForwardButton" Margin="0,0,5,0" ToolTip.Tip="Вперёд">
                    <TextBlock Text="➡️"/>
                </Button>
                <Separator Width="1" Margin="5,0"/>
                <Button x:Name="LeftCopyButton" Margin="0,0,5,0" ToolTip.Tip="Ctrl+C">
                    <TextBlock Text="📋 Копировать"/>
                </Button>
                <Button x:Name="LeftCutButton" Margin="0,0,5,0" ToolTip.Tip="Ctrl+X">
                    <TextBlock Text="✂️ Вырезать"/>
                </Button>
                <Button x:Name="LeftPasteButton" Margin="0,0,5,0" ToolTip.Tip="Ctrl+V">
                    <TextBlock Text="📄 Вставить"/>
                </Button>
                <Button x:Name="LeftDeleteButton" Margin="0,0,5,0" ToolTip.Tip="Del">
                    <TextBlock Text="🗑️ Удалить"/>
                </Button>
                <Button x:Name="LeftCreateFolderButton" Margin="0,0,5,0" ToolTip.Tip="Создать папку">
                    <TextBlock Text="📁 Папка"/>
                </Button>
                <Button x:Name="LeftRenameButton" Margin="0,0,5,0" ToolTip.Tip="F2">
                    <TextBlock Text="✏️ Переименовать"/>
                </Button>
                <Separator Width="1" Margin="10,0"/>
                <Button x:Name="LeftGoUpButton" Margin="0,0,5,0" ToolTip.Tip="↑">
                    <TextBlock Text="⬆️ Вверх"/>
                </Button>
                <Button x:Name="LeftRefreshButton" ToolTip.Tip="↻">
                    <TextBlock Text="🔄 Обновить"/>
                </Button>
            </StackPanel>
            
            <!-- Пустая зона в центре -->
            <Grid Grid.Column="1"/>
            
            <!-- Кнопки для правой панели -->
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button x:Name="RightForwardButton" Margin="0,0,5,0" ToolTip.Tip="Вперёд">
                    <TextBlock Text="➡️"/>
                </Button>
                <Button x:Name="RightBackButton" Margin="0,0,5,0" ToolTip.Tip="Назад">
                    <TextBlock Text="⬅️"/>
                </Button>
                <Separator Width="1" Margin="5,0"/>
                <Button x:Name="RightRefreshButton" Margin="0,0,5,0" ToolTip.Tip="↻">
                    <TextBlock Text="🔄 Обновить"/>
                </Button>
                <Button x:Name="RightGoUpButton" Margin="0,0,5,0" ToolTip.Tip="↑">
                    <TextBlock Text="⬆️ Вверх"/>
                </Button>
                <Separator Width="1" Margin="10,0"/>
                <Button x:Name="RightRenameButton" Margin="0,0,5,0" ToolTip.Tip="F2">
                    <TextBlock Text="✏️ Переименовать"/>
                </Button>
                <Button x:Name="RightCreateFolderButton" Margin="0,0,5,0" ToolTip.Tip="Создать папку">
                    <TextBlock Text="📁 Папка"/>
                </Button>
                <Button x:Name="RightDeleteButton" Margin="0,0,5,0" ToolTip.Tip="Del">
                    <TextBlock Text="🗑️ Удалить"/>
                </Button>
                <Button x:Name="RightPasteButton" Margin="0,0,5,0" ToolTip.Tip="Ctrl+V">
                    <TextBlock Text="📄 Вставить"/>
                </Button>
                <Button x:Name="RightCutButton" Margin="0,0,5,0" ToolTip.Tip="Ctrl+X">
                    <TextBlock Text="✂️ Вырезать"/>
                </Button>
                <Button x:Name="RightCopyButton" Margin="0,0,5,0" ToolTip.Tip="Ctrl+C">
                    <TextBlock Text="📋 Копировать"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Две панели -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*">
            <!-- Левая панель -->
            <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Margin="5" x:Name="LeftPanelBorder">
                <Grid RowDefinitions="Auto,*">
                    <Grid Grid.Row="0" ColumnDefinitions="2.5*,1.5*,Auto" Background="#444">
                        <TextBlock Grid.Column="0" Text="Имя" Foreground="White" Padding="5" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="Размер" Foreground="White" Padding="5" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="Дата" Foreground="White" Padding="5" VerticalAlignment="Center"/>
                    </Grid>
                    <ListBox x:Name="LeftPanelList" Grid.Row="1" ItemsSource="{Binding LeftPanel.Items}"
                             SelectedItem="{Binding LeftPanel.SelectedItem}"
                             DoubleTapped="LeftPanelList_DoubleTapped">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="2.5*,1.5*,Auto">
                                    <TextBlock Grid.Column="0" Text="{Binding Name}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding DisplaySize}" 
                                               Foreground="Gray" Margin="10,0,0,0"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Modified, StringFormat={}{0:dd.MM.yyyy HH:mm}}" 
                                               Foreground="Gray" Margin="10,0,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Правая панель -->
            <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1" Margin="5" x:Name="RightPanelBorder">
                <Grid RowDefinitions="Auto,*">
                    <Grid Grid.Row="0" ColumnDefinitions="2.5*,1.5*,Auto" Background="#444">
                        <TextBlock Grid.Column="0" Text="Имя" Foreground="White" Padding="5" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="Размер" Foreground="White" Padding="5" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="Дата" Foreground="White" Padding="5" VerticalAlignment="Center"/>
                    </Grid>
                    <ListBox x:Name="RightPanelList" Grid.Row="1" ItemsSource="{Binding RightPanel.Items}"
                             SelectedItem="{Binding RightPanel.SelectedItem}"
                             DoubleTapped="RightPanelList_DoubleTapped">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="2.5*,1.5*,Auto">
                                    <TextBlock Grid.Column="0" Text="{Binding Name}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding DisplaySize}" 
                                               Foreground="Gray" Margin="10,0,0,0"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Modified, StringFormat={}{0:dd.MM.yyyy HH:mm}}" 
                                               Foreground="Gray" Margin="10,0,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <!-- Статус бар -->
        <Border Grid.Row="2" Background="#333" Padding="5">
            <Grid ColumnDefinitions="*,Auto,*">
                <TextBlock Grid.Column="0" Text="{Binding LeftPanelStatusBar}" Foreground="White" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="|" Foreground="White" VerticalAlignment="Center" Margin="10,0"/>
                <TextBlock Grid.Column="2" Text="{Binding RightPanelStatusBar}" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
        </Border>
    </Grid>

</Window>