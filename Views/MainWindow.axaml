<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SmirnovCommander.ViewModels"
        xmlns:icons="using:IconPacks.Avalonia.Lucide"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="600"
        x:Class="SmirnovCommander.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="SmirnovCommander">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Панель инструментов -->
        <Grid Grid.Row="0" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <!-- Кнопки для левой панели -->
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button x:Name="LeftCopyButton" Margin="0,0,5,0" ToolTip.Tip="Копировать (Ctrl+C)">
                    <icons:PackIconLucide Kind="Copy" Width="20" Height="20"/>
                </Button>
                <Button x:Name="LeftCutButton" Margin="0,0,5,0" ToolTip.Tip="Вырезать (Ctrl+X)">
                    <icons:PackIconLucide Kind="Scissors" Width="20" Height="20"/>
                </Button>
                <Button x:Name="LeftPasteButton" Margin="0,0,5,0" ToolTip.Tip="Вставить (Ctrl+V)">
                    <icons:PackIconLucide Kind="Clipboard" Width="20" Height="20"/>
                </Button>
                <Button x:Name="LeftDeleteButton" Margin="0,0,5,0" ToolTip.Tip="Удалить (Del)">
                    <icons:PackIconLucide Kind="Trash2" Width="20" Height="20"/>
                </Button>
                <Button x:Name="LeftCreateFolderButton" Margin="0,0,5,0" ToolTip.Tip="Создать папку">
                    <icons:PackIconLucide Kind="FolderPlus" Width="20" Height="20"/>
                </Button>
                <Button x:Name="LeftRenameButton" Margin="0,0,5,0" ToolTip.Tip="Переименовать (F2)">
                    <icons:PackIconLucide Kind="PenLine" Width="20" Height="20"/>
                </Button>
                <Separator Width="1" Margin="10,0"/>
                <Button x:Name="LeftGoUpButton" Margin="0,0,5,0" ToolTip.Tip="На уровень выше">
                    <icons:PackIconLucide Kind="ArrowUp" Width="20" Height="20"/>
                </Button>
                <Button x:Name="LeftRefreshButton" ToolTip.Tip="Обновить">
                    <icons:PackIconLucide Kind="RefreshCw" Width="20" Height="20"/>
                </Button>
            </StackPanel>
            
            <!-- Пустая зона в центре -->
            <Grid Grid.Column="1"/>
            
            <!-- Кнопки для правой панели -->
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button x:Name="RightRefreshButton" Margin="0,0,5,0" ToolTip.Tip="Обновить">
                    <icons:PackIconLucide Kind="RefreshCw" Width="20" Height="20"/>
                </Button>
                <Button x:Name="RightGoUpButton" Margin="0,0,5,0" ToolTip.Tip="На уровень выше">
                    <icons:PackIconLucide Kind="ArrowUp" Width="20" Height="20"/>
                </Button>
                <Separator Width="1" Margin="10,0"/>
                <Button x:Name="RightRenameButton" Margin="0,0,5,0" ToolTip.Tip="Переименовать (F2)">
                    <icons:PackIconLucide Kind="PenLine" Width="20" Height="20"/>
                </Button>
                <Button x:Name="RightCreateFolderButton" Margin="0,0,5,0" ToolTip.Tip="Создать папку">
                    <icons:PackIconLucide Kind="FolderPlus" Width="20" Height="20"/>
                </Button>
                <Button x:Name="RightDeleteButton" Margin="0,0,5,0" ToolTip.Tip="Удалить (Del)">
                    <icons:PackIconLucide Kind="Trash2" Width="20" Height="20"/>
                </Button>
                <Button x:Name="RightPasteButton" Margin="0,0,5,0" ToolTip.Tip="Вставить (Ctrl+V)">
                    <icons:PackIconLucide Kind="Clipboard" Width="20" Height="20"/>
                </Button>
                <Button x:Name="RightCutButton" Margin="0,0,5,0" ToolTip.Tip="Вырезать (Ctrl+X)">
                    <icons:PackIconLucide Kind="Scissors" Width="20" Height="20"/>
                </Button>
                <Button x:Name="RightCopyButton" Margin="0,0,5,0" ToolTip.Tip="Копировать (Ctrl+C)">
                    <icons:PackIconLucide Kind="Copy" Width="20" Height="20"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Две панели -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*">
            <!-- Левая панель -->
            <Border Grid.Column="0" BorderBrush="Gray" BorderThickness="1" Margin="5" x:Name="LeftPanelBorder">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0" Text="{Binding LeftPanel.CurrentPath}" 
                               Background="#333" Foreground="White" Padding="5"/>
                    <ListBox x:Name="LeftPanelList" Grid.Row="1" ItemsSource="{Binding LeftPanel.Items}"
                             SelectedItem="{Binding LeftPanel.SelectedItem}"
                             DoubleTapped="LeftPanelList_DoubleTapped">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="{Binding Name}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding DisplaySize}" 
                                               Foreground="Gray" Margin="10,0,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Правая панель -->
            <Border Grid.Column="1" BorderBrush="Gray" BorderThickness="1" Margin="5" x:Name="RightPanelBorder">
                <Grid RowDefinitions="Auto,*">
                    <TextBlock Grid.Row="0" Text="{Binding RightPanel.CurrentPath}" 
                               Background="#333" Foreground="White" Padding="5"/>
                    <ListBox x:Name="RightPanelList" Grid.Row="1" ItemsSource="{Binding RightPanel.Items}"
                             SelectedItem="{Binding RightPanel.SelectedItem}"
                             DoubleTapped="RightPanelList_DoubleTapped">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="{Binding Name}"/>
                                    <TextBlock Grid.Column="1" Text="{Binding DisplaySize}" 
                                               Foreground="Gray" Margin="10,0,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <!-- Статус бар -->
        <Border Grid.Row="2" Background="#333" Padding="5">
            <Grid ColumnDefinitions="*,Auto,*">
                <TextBlock Grid.Column="0" Text="{Binding LeftPanelStatusBar}" Foreground="White" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="|" Foreground="White" VerticalAlignment="Center" Margin="10,0"/>
                <TextBlock Grid.Column="2" Text="{Binding RightPanelStatusBar}" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Right"/>
            </Grid>
        </Border>
    </Grid>

</Window>